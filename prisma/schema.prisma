// Prisma Schema for Affiliate Data Dashboard
// Database: Vercel Postgres (Supabase compatible)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 订单主表
model Order {
  id                String   @id @default(uuid())
  platform          Platform
  platformOrderId   String   // 平台原始订单号
  status            OrderStatus
  commissionAmount  Decimal  @map("commission_amount")
  commissionCurrency String  @default("USD") @map("commission_currency") // USD, EUR, GBP, etc.
  commissionUsd     Decimal  @map("commission_usd")
  commissionRmb     Decimal  @map("commission_rmb")
  saleAmount        Decimal? @map("sale_amount")
  saleCurrency      String?  @default("USD") @map("sale_currency")
  orderDate         DateTime @map("order_date")
  clickDate         DateTime? @map("click_date")
  customerName      String?  @map("customer_name")
  customerEmail     String?  @map("customer_email")
  productName       String?  @map("product_name")
  productSku        String?  @map("product_sku")
  orderUrl          String?  @map("order_url")
  
  // 取消原因 (当 status = DECLINED 时)
  declineReason     String?  @map("decline_reason")
  
  // 人工审核标记
  needsManualReview Boolean  @default(false) @map("needs_manual_review")
  manualReviewReason String? @map("manual_review_reason")
  
  // 原始平台返回的 JSON 数据
  rawData           Json     @map("raw_data")
  
  // 同步时间戳
  syncedAt          DateTime @default(now()) @map("synced_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([platform, platformOrderId])
  @@index([platform])
  @@index([status])
  @@index([orderDate])
  @@index([needsManualReview])
  @@map("orders")
}

// 同步日志表
model SyncLog {
  id          String   @id @default(uuid())
  platform    Platform
  status      SyncStatus
  message     String?
  ordersFound Int      @default(0) @map("orders_found")
  ordersNew   Int      @default(0) @map("orders_new")
  ordersUpdated Int    @default(0) @map("orders_updated")
  startedAt   DateTime @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  errorJson   Json?    @map("error_json")

  @@index([platform])
  @@index([startedAt])
  @@map("sync_logs")
}

// 平台配置表
model PlatformConfig {
  id         String   @id @default(uuid())
  platform   Platform @unique
  apiKey     String   @map("api_key")
  apiSecret  String?  @map("api_secret")
  accountId  String?  @map("account_id")
  additionalConfig Json? @map("additional_config")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("platform_configs")
}

// 枚举类型
enum Platform {
  AWIN
  IMPACT
  LEADDYNO
  GOAFFPRO
}

enum OrderStatus {
  PENDING
  APPROVED
  DECLINED
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}
